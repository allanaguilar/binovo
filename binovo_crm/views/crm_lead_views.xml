<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- crm.lead inherit form view -->
    <record id="crm_lead_view_form" model="ir.ui.view">
        <field name="name">crm.lead.inherit.view.form</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form" />
        <field name="arch" type="xml">
            
            <xpath expr="//group[@name='opportunity_partner']/field[last()]" position="after">
                <field name="source_type" />
            </xpath>
            <xpath expr="//group[@name='lead_info']/field[last()]" position="after">
                <field name="source_type" />
            </xpath>
        </field>
    </record>

    <!-- crm.lead inherit tree view -->
    <record id="crm_case_tree_view_leads" model="ir.ui.view">
        <field name="name">crm.lead.inherit.view.tree</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="arch" type="xml">
            <field name="source_id" position="before">
                <field name="source_type"/>
            </field>
        </field>
    </record>
</odoo>