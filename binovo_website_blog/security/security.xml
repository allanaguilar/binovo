<?xml version='1.0' encoding='utf-8'?>

<odoo>
    <data noupdate="1">

        <record id="blog_blog_company_rule" model="ir.rule">
            <field name="name">Blog per Company</field>
            <field name="model_id" ref="binovo_website_blog.model_blog_blog"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="blog_post_company_rule" model="ir.rule">
            <field name="name">Post per Company</field>
            <field name="model_id" ref="binovo_website_blog.model_blog_post"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>