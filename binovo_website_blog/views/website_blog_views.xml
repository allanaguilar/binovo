<?xml version='1.0' encoding='utf-8'?>
<odoo>
   
    <!-- blog.blog inherit tree view -->
    <record id="view_blog_blog_list" model="ir.ui.view">
        <field name="name">blog.blog.inherit.view.tree</field>
        <field name="model">blog.blog</field>
        <field name="inherit_id" ref="website_blog.view_blog_blog_list"/>
        <field name="arch" type="xml">
            <field name="website_id" position="before">
                <field name="company_id"/>
            </field>
        </field>
    </record>

    <!-- blog.blog inherit form view -->
    <record id="view_blog_blog_form" model="ir.ui.view">
        <field name="name">blog.blog.inherit.view.form</field>
        <field name="model">blog.blog</field>
        <field name="inherit_id" ref="website_blog.view_blog_blog_form"/>
        <field name="arch" type="xml">
            <field name="website_id" position="before">
                <field name="company_id"/>
            </field>
        </field>
    </record>

    <!-- blog.post inherit tree view -->
    <record id="view_blog_post_list" model="ir.ui.view">
        <field name="name">blog.post.inherit.view.tree</field>
        <field name="model">blog.post</field>
        <field name="inherit_id" ref="website_blog.view_blog_post_list"/>
        <field name="arch" type="xml">
            <field name="blog_id" position="before">
                <field name="company_id"/>
            </field>
        </field>
    </record>

</odoo>